# ============================================================
# 环境变量配置示例，复制此文件为 .env.local 并填入真实值
# 注意：.env.local 不要提交到 Git！已在 .gitignore 中忽略
# ============================================================

# 阿里云百炼 / DashScope API Key
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# SearchAPI Key（用于网页搜索工具）
# 获取地址：https://www.searchapi.io/
SEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Pexels API Key（用于图片搜索 MCP 服务）
# 获取地址：https://www.pexels.com/api/
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# 高德地图 MCP API Key（用于地图服务）
AMAP_MAPS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 启动方式示例（Linux / macOS）：
#   export DASHSCOPE_API_KEY=sk-xxx
#   export SEARCH_API_KEY=xxx
#   export PEXELS_API_KEY=xxx
#   ./mvnw spring-boot:run
#
# Windows PowerShell：
#   $env:DASHSCOPE_API_KEY="sk-xxx"
#   $env:SEARCH_API_KEY="xxx"
#   $env:PEXELS_API_KEY="xxx"
#   .\mvnw.cmd spring-boot:run
# ============================================================
